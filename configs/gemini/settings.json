{
  "$schema": "https://raw.githubusercontent.com/google-gemini/gemini-cli/main/schemas/settings.schema.json",
  "mcpServers": {
    "hub": {
      "url": "http://localhost:3000/sse"
    }
  },

  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "enablePermanentToolApproval": true,
    "folderTrust": {
      "enabled": true
    },
    "environmentVariableRedaction": {
      "enabled": true
    }
  },
  "ui": {
    "theme": "Dracula",
    "showStatusInTitle": true,
    "hideBanner": true,
    "footer": {
      "hideContextPercentage": false,
      "items": [
        "workspace",
        "git-branch",
        "sandbox",
        "model-name",
        "context-used",
        "quota"
      ]
    },
    "showMemoryUsage": false,
    "showCitations": true,
    "showModelInfoInChat": true
  },
  "general": {
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d"
    },
    "plan": {
      "enabled": true
    }
  },
  "context": {
    "loadMemoryFromIncludeDirectories": true,
    "fileName": [
      "CLAUDE.md",
      "GEMINI.md",
      "AGENTS.md"
    ]
  },
  "tools": {
    "shell": {
      "showColor": true
    }
  },
  "ide": {
    "enabled": true
  },
  "hooks": {
    "BeforeAgent": [
      {
        "hooks": []
      }
    ],
    "AfterAgent": [
      {
        "hooks": []
      }
    ],
    "AfterTool": [
      {
        "hooks": []
      }
    ],
    "BeforeTool": [
      {
        "matcher": "exit_plan_mode",
        "hooks": [
          {
            "type": "command",
            "command": "plannotator",
            "timeout": 345600
          }
        ]
      }
    ]
  }
}
