{
  "mcpServers": {
    "qmd": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "qmd", "mcp"],
      "shared": true,
      "enabled": true
    },
    "fff": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "fff-mcp"],
      "shared": true,
      "enabled": true
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "shared": true,
      "enabled": true
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "shared": true,
      "enabled": true
    },
    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": {
        "MEMORY_FILE_PATH": "$HOME/.ai-tools/memory.jsonl"
      },
      "shared": true,
      "enabled": true
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/dinesh/projects"
      ],
      "shared": true,
      "enabled": true
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--headless"
      ],
      "shared": true,
      "enabled": true
    }
  }
}
